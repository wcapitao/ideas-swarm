# Copy to .env and fill in. .env is gitignored.

# Anthropic
ANTHROPIC_API_KEY=

# Optional: alternative providers when comparing
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# KB paths
KB_ROOT=./kb
KB_RAW=./kb/raw
KB_WIKI=./kb/wiki

# Logging
LOG_LEVEL=INFO

# Neo4j graph sync
# For self-hosted Neo4j Query API use http://localhost:7474 or https://host:7473
# NEO4J_URL=
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

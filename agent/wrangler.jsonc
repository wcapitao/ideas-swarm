{
	"name": "ai-ideator",
	"main": "src/index.ts",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": ["nodejs_compat"],

	"durable_objects": {
		"bindings": [{ "name": "IDEATOR", "class_name": "IdeatorAgent" }]
	},

	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["IdeatorAgent"]
		}
	],

	"vars": {
		"ENVIRONMENT": "development",
		"AIG_GATEWAY_ID": "ai-ideator"
	},

	"assets": {
		"directory": "./public"
	}
}

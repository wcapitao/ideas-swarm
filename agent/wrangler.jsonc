{
  "name": "ai-ideator",
  // Set CLOUDFLARE_ACCOUNT_ID env var instead of hardcoding here
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "durable_objects": {
    "bindings": [
      { "name": "IDEATOR", "class_name": "IdeatorAgent" },
      { "name": "GOAL", "class_name": "GoalSession" }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["IdeatorAgent", "GoalSession"]
    }
  ],

  // --- Data stores ---

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai-ideator",
      "database_id": "aad58b7e-cf3f-4542-bb04-6b26ff7d4bc9",
      "migrations_dir": "migrations"
    }
  ],

  "r2_buckets": [
    {
      "binding": "RAW",
      "bucket_name": "ai-ideator-raw"
    }
  ],

  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "concepts-v1"
    }
  ],

  // --- Queues ---

  "queues": {
    "producers": [
      { "binding": "HERD_QUEUE", "queue": "ai-ideator-herd" },
      { "binding": "ENRICH_QUEUE", "queue": "ai-ideator-enrich" },
      { "binding": "EVAL_QUEUE", "queue": "ai-ideator-eval" }
    ]
  },

  // --- AI ---

  "ai": {
    "binding": "AI"
  },

  "vars": {
    "ENVIRONMENT": "development",
    "AIG_GATEWAY_ID": "ai-ideator"
  }
}
